      "type": "promptString",
      "description": "Waarde voor 'korte_beschrijving' (definieer-agent-boundary)"
    },
    {
      "id": "in_capability_architect_definieer_agent_boundary_template_file",
      "type": "promptString",
      "description": "Waarde voor 'template_file' (definieer-agent-boundary)"
    }
  ]
