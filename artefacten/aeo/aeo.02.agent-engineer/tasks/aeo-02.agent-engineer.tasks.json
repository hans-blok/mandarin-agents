{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "aeo.02 - agent-engineer: realiseer-agent-prompts",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.agent-engineer/runner/agent-engineer.runner.py",
        "realiseer-agent-prompts",
        "--agent-naam",
        "${input:in_agent_engineer_realiseer_agent_prompts_agent_naam}",
        "--intent",
        "${input:in_agent_engineer_realiseer_agent_prompts_intent}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - agent-engineer: realiseer-agent-runner",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.agent-engineer/runner/agent-engineer.runner.py",
        "realiseer-agent-runner",
        "--agent-naam",
        "${input:in_agent_engineer_realiseer_agent_runner_agent_naam}",
        "--contract-folder",
        "${input:in_agent_engineer_realiseer_agent_runner_contract_folder}",
        "--runner-output-folder",
        "${input:in_agent_engineer_realiseer_agent_runner_runner_output_folder}",
        "--overwrite-existing",
        "${input:in_agent_engineer_realiseer_agent_runner_overwrite_existing}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - agent-engineer: realiseer-agent-taskconfiguratie",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.agent-engineer/runner/agent-engineer.runner.py",
        "realiseer-agent-taskconfiguratie",
        "--agent-naam",
        "${input:in_agent_engineer_realiseer_agent_taskconfiguratie_agent_naam}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - agent-engineer: pipeline",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.agent-engineer/runner/agent-engineer.runner.py",
        "pipeline",
        "${input:in_agent_engineer_pipeline_agent}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "in_agent_engineer_realiseer_agent_prompts_agent_naam",
      "type": "promptString",
      "description": "Naam van de agent waarvoor prompts worden gerealiseerd"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_prompts_intent",
      "type": "promptString",
      "description": "Specifieke intent waarvoor prompt wordt gerealiseerd (Optioneel)"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_runner_agent_naam",
      "type": "promptString",
      "description": "Naam van de agent waarvoor runners worden gerealiseerd"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_runner_contract_folder",
      "type": "promptString",
      "description": "Pad naar de folder met agent-contracten (Optioneel)"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_runner_runner_output_folder",
      "type": "promptString",
      "description": "Folder voor gegenereerde runners (Optioneel)"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_runner_overwrite_existing",
      "type": "promptString",
      "description": "Of bestaande runner-scripts overschreven mogen worden (Optioneel)"
    },
    {
      "id": "in_agent_engineer_realiseer_agent_taskconfiguratie_agent_naam",
      "type": "promptString",
      "description": "Naam van de agent waarvoor tasks worden gerealiseerd"
    },
    {
      "id": "in_agent_engineer_pipeline_agent",
      "type": "promptString",
      "description": "Agent naam voor pipeline"
    }
  ]
}
