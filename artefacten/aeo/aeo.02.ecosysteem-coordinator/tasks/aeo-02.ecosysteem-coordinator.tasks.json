        "--value-stream",
        "${input:in_ecosysteem_coordinator_consulteer_canon_value_stream}",
        "--intent",
        "${input:in_ecosysteem_coordinator_consulteer_canon_intent}",
        "--canon-path",
        "${input:in_ecosysteem_coordinator_consulteer_canon_canon_path}",
