        "${input:in_ecosysteem_coordinator_consulteer_canon_grondslagen}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - ecosysteem-coordinator: genereer-instructies",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.ecosysteem-coordinator/runner/ecosysteem-coordinator.runner.py",
        "genereer-instructies",
        "--agent",
        "${input:in_ecosysteem_coordinator_genereer_instructies_agent}",
        "--intent",
        "${input:in_ecosysteem_coordinator_genereer_instructies_intent}",
        "--execution-file",
        "${input:in_ecosysteem_coordinator_genereer_instructies_execution_file}",
        "--method",
        "${input:in_ecosysteem_coordinator_genereer_instructies_method}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - ecosysteem-coordinator: activeer-workspace-configuratie",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.ecosysteem-coordinator/runner/ecosysteem-coordinator.runner.py",
        "activeer-workspace-configuratie"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "aeo.02 - ecosysteem-coordinator: valideer-agent-structuur",
      "type": "process",
      "command": "python",
      "args": [
        "artefacten/aeo/aeo.02.ecosysteem-coordinator/runner/ecosysteem-coordinator.runner.py",
        "valideer-agent-structuur",
        "--agent-naam",
        "${input:in_ecosysteem_coordinator_valideer_agent_structuur_agent_naam}",
        "--value-stream-fase",
        "${input:in_ecosysteem_coordinator_valideer_agent_structuur_value_stream_fase}",
        "--output-format",
        "${input:in_ecosysteem_coordinator_valideer_agent_structuur_output_format}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "in_ecosysteem_coordinator_consulteer_canon_agent",
      "type": "promptString",
      "description": "Agent-naam (bijv. agent-engineer)"
    },
    {
      "id": "in_ecosysteem_coordinator_consulteer_canon_value_stream",
      "type": "promptString",
      "description": "Value stream code (bijv. aeo)"
    },
    {
      "id": "in_ecosysteem_coordinator_consulteer_canon_intent",
      "type": "promptString",
      "description": "Intent-naam (bijv. realiseer-agent-prompts)"
    },
    {
      "id": "in_ecosysteem_coordinator_consulteer_canon_canon_path",
      "type": "promptString",
      "description": "Pad naar lokale canon directory",
      "default": "../canon"
    },
    {
      "id": "in_ecosysteem_coordinator_consulteer_canon_grondslagen",
      "type": "promptString",
      "description": "Komma-gescheiden lijst van grondslagen (bijv. doctrine-agent-charter-normering.md)"
    },
    {
      "id": "in_ecosysteem_coordinator_genereer_instructies_agent",
      "type": "promptString",
      "description": "Agent-naam (bijv. agent-engineer)"
    },
    {
      "id": "in_ecosysteem_coordinator_genereer_instructies_intent",
      "type": "promptString",
      "description": "Intent-naam (bijv. realiseer-agent-prompts)"
    },
    {
      "id": "in_ecosysteem_coordinator_genereer_instructies_execution_file",
      "type": "promptString",
      "description": "Pad naar execution output bestand",
      "default": "prompt-instructions/execution.md"
    },
    {
      "id": "in_ecosysteem_coordinator_genereer_instructies_method",
      "type": "pickString",
      "description": "Generatie methode",
      "options": ["append", "overwrite"],
      "default": "append"
    },
    {
      "id": "in_ecosysteem_coordinator_valideer_agent_structuur_agent_naam",
      "type": "promptString",
      "description": "Agent-naam om te valideren"
    },
    {
      "id": "in_ecosysteem_coordinator_valideer_agent_structuur_value_stream_fase",
      "type": "promptString",
      "description": "Value stream fase (bijv. aeo.02)"
    },
    {
      "id": "in_ecosysteem_coordinator_valideer_agent_structuur_output_format",
      "type": "pickString",
      "description": "Output formaat voor validatierapport",
      "options": ["markdown", "json"],
      "default": "markdown"
    }
  ]
}
