{
  "tasks": [
    {
      "label": "Canon: pull + copy hash",
      "type": "shell",
      "command": "cd ../mandarin-canon; git pull --ff-only; git rev-parse --short HEAD | Set-Clipboard",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Artefact Digest: verify",
      "type": "process",
      "command": "python",
      "args": [
        "scripts/artefact_digest.py",
        "verify",
        "--verbose"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Artefact Digest: update (alle bestanden)",
      "type": "process",
      "command": "python",
      "args": [
        "scripts/artefact_digest.py",
        "update"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Agent: Execute (Generate + Save)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-Command",
        "$timestamp = Get-Date -Format 'yyyyMMddHHmmss'; $agent = '${input:agentName}'; $intent = '${input:intentName}'; $filename = \"executions/$timestamp-$agent.$intent.md\"; [Console]::OutputEncoding = [System.Text.Encoding]::UTF8; $env:PYTHONIOENCODING='utf-8'; python artefacten/aeo/aeo.02.agent-engineer/runner/agent-engineer.runner.py generate-instructions --agent $agent --intent $intent --execution-file $filename; if ($LASTEXITCODE -eq 0) { code $filename }"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
